# ─── API Keys (Choose one) ──────────────────────────────

# For free models via OpenRouter (recommended for free usage)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OR for Anthropic directly (paid)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Hotkey ─────────────────────────────────────────────
# HOTKEY=ctrl+shift+t

# ─── Translation ────────────────────────────────────────
# TARGET_LANG=ru
# SOURCE_LANG=en

# ─── EasyOCR ───────────────────────────────────────────
# EASYOCR_LANGS=ru,en
# EASYOCR_GPU=auto
# EASYOCR_CONFIDENCE_THRESHOLD=0.25

# ─── Popup ──────────────────────────────────────────────
# POPUP_TIMEOUT_SEC=10

# ─── Overlay ────────────────────────────────────────────
# OVERLAY_OPACITY=0.85
# OVERLAY_FONT_SIZE=14
