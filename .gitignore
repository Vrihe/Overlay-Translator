# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
*.whl

# ─── PyInstaller Build Artifacts ────────────────────────
dist/
build/
*.manifest
# Note: build.spec and translator.spec are tracked in git for reproducible builds!

# ─── Executables & Binary Artifacts ─────────────────────
*.exe

# ─── Virtual Environments & Secrets ─────────────────────
venv/
.venv/
env/
.env/
.env

# ─── IDE / Editors ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ─── OS files ────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ─── Project-specific ───────────────────────────────────
# Translation / OCR cache (keep folder, ignore DB & contents)
cache/*
!cache/__init__.py

# Captured screenshots
screenshots/

# Tesseract temp output
*.tiff
*.tif

# Logs
logs/
*.log

# User settings (generated at runtime)
settings.json
